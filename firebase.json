{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "**/*.map", ".git/**", "cloud-functions/**"],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      { "source": "**/*.@(js|css)", "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000" }] },
      { "source": "manifest.json", "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }] },
      { "source": "service-worker.js", "headers": [{ "key": "Service-Worker-Allowed", "value": "/" }] }
    ]
  }
}
